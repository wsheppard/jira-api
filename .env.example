# Copy this file to .env and fill in your credentials.

# API tokens only; hard-coded email and URLs/repos in code.
JIRA_API_TOKEN=your_jira_api_token
BITBUCKET_API_TOKEN=your_bitbucket_api_token
GITHUB_TOKEN=your_github_token
OPENAI_API_KEY=your_openai_api_key
OPENAI_JQL_MODEL=gpt-4.1-mini
XAI_API_KEY=your_xai_api_key
XAI_JQL_MODEL=grok-3-mini

# Optional site build trigger integration (DEV).
# Set provider to api_bridges (recommended for your setup), and set the endpoint path.
# Set provider to docker_socket to build inside docker on the API host using the docker socket.
# If you keep api_bridges, set SITE_BUILD_TRIGGER_PATH accordingly.
SITE_BUILD_PROVIDER=docker_socket
# Set either a path under api-bridges (e.g. /v1/monorepo/build-trigger) or a full URL.
SITE_BUILD_TRIGGER_PATH=
SITE_BUILD_TRIGGER_TIMEOUT_SECONDS=30
SITE_BUILD_REPO_URL=https://github.com/palliativa/monorepo.git
SITE_BUILD_BUILDER_IMAGE=node:18-alpine
SITE_BUILD_WEB_CONTAINER=jira-www
SITE_BUILD_WEB_PATH=/usr/share/caddy
SITE_BUILD_CONTAINER_WORKDIR=/workspace
SITE_BUILD_BUILD_COMMAND=npm ci && npm run build
SITE_BUILD_OUTPUT_DIR=build
SITE_BUILD_CONTAINER_BUILD_SCRIPT_TIMEOUT_SECONDS=1200
SITE_BUILD_DOCKER_COMMAND_TIMEOUT_SECONDS=900
