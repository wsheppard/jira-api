# Copy this file to .env and fill in your credentials.

# API tokens only; hard-coded email and URLs/repos in code.
JIRA_API_TOKEN=your_jira_api_token
BITBUCKET_API_TOKEN=your_bitbucket_api_token
GITHUB_TOKEN=your_github_token
OPENAI_API_KEY=your_openai_api_key
OPENAI_JQL_MODEL=gpt-4.1-mini
XAI_API_KEY=your_xai_api_key
XAI_JQL_MODEL=grok-3-mini

# Optional site build trigger integration (DEV).
# Set provider to api_bridges (recommended for your setup), and set the endpoint path.
SITE_BUILD_PROVIDER=api_bridges
# Set either a path under api-bridges (e.g. /v1/monorepo/build-trigger) or a full URL.
SITE_BUILD_TRIGGER_PATH=
SITE_BUILD_TRIGGER_TIMEOUT_SECONDS=30
